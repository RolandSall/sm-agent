<?xml version="1.0" encoding="UTF-8"?>
<!--
  All logging goes to STDERR. This is required for the MCP stdio transport: stdout is the
  JSON-RPC channel between the harness and this server, so any log line on stdout would corrupt
  the protocol. Logging to stderr is harmless in HTTP/server mode too.
-->
<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
