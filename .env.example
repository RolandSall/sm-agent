# Copy to .env and fill in. NEVER commit .env (it holds your token).
JIRA_BASE_URL=https://your-jira.example.com
JIRA_TOKEN=your-personal-access-token

# One or more project keys the team works in, comma-separated. Both count as "ours".
# Example: JIRA_PROJECT_KEYS=PROJ,PLTF
JIRA_PROJECT_KEYS=PROJ,PLTF

# The Agile board id (rapidView) — find it with scripts/check-jira.sh.
JIRA_BOARD_ID=

# OPTIONAL fallback. A board can have several active sprints at once; this substring disambiguates
# which one is the team's current sprint. When unset (the default), the server picks by date/first —
# and the agent can call list_sprints to enumerate the sprints and choose one by name instead.
JIRA_SPRINT_FILTER=

# DEV-ONLY: skip TLS cert validation when the corporate Jira CA isn't in the JVM truststore
# (curl works via the OS store; the JVM has its own). Local piloting only — never true in prod.
JIRA_INSECURE_TLS=false
